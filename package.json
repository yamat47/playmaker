{
  "name": "playmaker",
  "version": "0.0.0",
  "private": true,
  "description": "アメリカンフットボールのプレー図を作成・表示する JavaScript ライブラリ",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "main": "./dist/playmaker.cjs",
  "module": "./dist/playmaker.js",
  "types": "./dist/playmaker.d.ts",
  "exports": {
    ".": {
      "types": "./dist/playmaker.d.ts",
      "import": "./dist/playmaker.js",
      "require": "./dist/playmaker.cjs"
    },
    "./styles.css": "./dist/playmaker.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite demo --config vite.config.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "subset-font": "^2.5.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  }
}
